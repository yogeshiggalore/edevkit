{
    "C_Cpp.intelliSenseEngine": "disabled",
    "clangd.checkUpdates": true,
    "clangd.arguments": [
        "--background-index",
        "--header-insertion=never",
        "--completion-style=detailed",
        "--pch-storage=memory",
        "--clang-tidy"
    ],
    "files.associations": {
        "*.overlay": "dts",
        "*.dtsi": "dts",
        "*.pio": "c"
    }
}
