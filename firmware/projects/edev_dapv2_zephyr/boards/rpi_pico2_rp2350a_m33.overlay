/*
 * SPDX-License-Identifier: Apache-2.0
 *
 * edev_dapv2 (Zephyr port) — board overlay for Raspberry Pi Pico 2 (RP2350A,
 * Cortex-M33 cores).
 *
 * Wires:
 *   - USB CDC ACM as the Zephyr console (replaces UART0 console default)
 *   - LED alias to the on-board GPIO25 LED (heartbeat)
 *   - Reserves SWD pins (GPIO2/3) and JTAG pins (GPIO4/5) for later milestones;
 *     no driver is attached yet — driver bindings land with the swdp_pio_rpi
 *     driver in M4.
 */

/ {
	chosen {
		zephyr,console = &cdc_acm_uart0;
		zephyr,shell-uart = &cdc_acm_uart0;
	};

	aliases {
		led-status = &led0;
	};

	leds {
		compatible = "gpio-leds";
		led0: led_0 {
			gpios = <&gpio0 25 GPIO_ACTIVE_HIGH>;
			label = "On-board heartbeat LED";
		};
	};

	/*
	 * SWD Debug Port — M2 placeholder using upstream zephyr,swdp-gpio
	 * (drivers/dp/swdp_bitbang.c). Pin assignments match probe_pins.h in
	 * the pico-sdk project:
	 *   SWCLK = GPIO2, SWDIO = GPIO3 (input pull-up by default).
	 *
	 * This will be replaced by zephyr,swdp-pio-rpi (PIO-driven, 25 MHz) in
	 * M3 — but the upstream GPIO bit-banger is enough to validate
	 * USB-CMSIS-DAP-v2 enumeration end-to-end with probe-rs first.
	 */
	dp0: dp0 {
		compatible = "zephyr,swdp-gpio";
		status = "okay";
		clk-gpios = <&gpio0 2 GPIO_ACTIVE_HIGH>;
		dio-gpios = <&gpio0 3 GPIO_PULL_UP>;
		port-write-cycles = <2>;
	};
};

&zephyr_udc0 {
	cdc_acm_uart0: cdc_acm_uart0 {
		compatible = "zephyr,cdc-acm-uart";
		label = "edev_dapv2 CDC log";
	};
};
