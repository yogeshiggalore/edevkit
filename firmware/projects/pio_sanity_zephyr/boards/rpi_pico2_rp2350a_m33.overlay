/*
 * Board overlay: console via USB CDC, expose PIO1 (matches edev_dapv2_zephyr).
 */
/ {
	chosen {
		zephyr,console = &cdc_acm_uart0;
		zephyr,shell-uart = &cdc_acm_uart0;
	};
};

&zephyr_udc0 {
	cdc_acm_uart0: cdc_acm_uart0 {
		compatible = "zephyr,cdc-acm-uart";
		label = "pio_sanity CDC log";
	};
};

&pio1 {
	status = "okay";
};
