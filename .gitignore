# macOS
.DS_Store

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Zephyr / west build outputs
build/
build-*/

# Editors / IDEs
# Share the workspace-level VS Code config (clangd setup, recommended
# extensions) so every contributor gets the same IntelliSense experience.
# Ignore everything else under .vscode/ — that's per-developer state.
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
.idea/
*.swp

# clangd index cache (auto-generated per checkout). Match at any depth so
# per-sample dirs (e.g. firmware/samples/led/led_01/.cache/clangd/) are
# also ignored, not just the repo-root .cache/.
**/.cache/

# Per-sample compile_commands.json symlinks (created by edev_build →
# _edev_link_compile_db; point at sysbuild's nested compile DB).
compile_commands.json

# Node tooling (docs hub uses npm only for local asset builds; deps are
# regenerated by `npm install`).
node_modules/

# Reference PDFs and large captures (some are third-party copyrighted —
# e.g. usb-complete.pdf). Keep them out of the public repo; contributors
# pull them down separately when needed.
documents/

# KiCad auto-generated state (snapshots + backup ZIPs). KiCad keeps a
# rolling local history under .history/ (with its own embedded .git) and
# timestamped *.zip snapshots under <project>-backups/. Both are user-
# local recovery data — never commit. Source files live alongside.
.history/
*-backups/
fp-info-cache

# Local-only env / credential files
.env
.env.*
!.env.example
log.log
